{
  "description": "Spotlight",
  "extends": "light_point",
  "renderers": [
    {
      "type": "point",
      "color": "$color"
    },
    {
      "type": "orientation",
      "color": "$color"
    }
  ],
  "params": {
    "constant_attenuation": {
      "display": "Constant Attenuation",
      "type": "float",
      "default": 0.0,
      "minimum": 0.0
    },
    "linear_attenuation": {
      "display": "Linear Attenuation",
      "type": "float",
      "default": 0.0,
      "minimum": 0.0
    },
    "quadratic_attenuation": {
      "display": "Quadratic Attenuation",
      "type": "float",
      "default": 1.0,
      "minimum": 0.0
    },
    "attenuation_multiplier": {
      "display": "Attenuation Multiplier",
      "type": "float",
      "default": 2.0,
      "minimum": 0.0
    },
    "bright_angle": {
      "display": "Bright Angle",
      "type": "float",
      "default": 45.0,
      "minimum": 0.0,
      "maximum": 90.0
    },
    "fading_angle": {
      "display": "Fading angle",
      "type": "float",
      "default": 60.0,
      "minimum": 0.0,
      "maximum": 90.0
    }
  }
}