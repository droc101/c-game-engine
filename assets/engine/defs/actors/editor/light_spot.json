{
  "description": "Spotlight",
  "extends": "light_point",
  "renderers": [
    {
      "type": "point",
      "color": "$color"
    },
    {
      "type": "orientation",
      "color": "$color"
    },
    {
      "type": "cone",
      "color": [
        "$color:r*0.5",
        "$color:g*0.5",
        "$color:b*0.5"
      ],
      "angle": "$fading_angle",
      "length": "falloff($constant_attenuation, $linear_attenuation, $quadratic_attenuation, $attenuation_multiplier, 1)",
      "is_gizmo": true,
      "num_sides": 32
    },
    {
      "type": "cone",
      "color": "$color",
      "angle": "$bright_angle",
      "length": "falloff($constant_attenuation, $linear_attenuation, $quadratic_attenuation, $attenuation_multiplier, 50)",
      "is_gizmo": true,
      "num_sides": 32
    }
  ],
  "params": {
    "constant_attenuation": {
      "display": "Constant Attenuation",
      "type": "float",
      "default": 0.0,
      "minimum": 0.0
    },
    "linear_attenuation": {
      "display": "Linear Attenuation",
      "type": "float",
      "default": 0.0,
      "minimum": 0.0
    },
    "quadratic_attenuation": {
      "display": "Quadratic Attenuation",
      "type": "float",
      "default": 1.0,
      "minimum": 0.0
    },
    "attenuation_multiplier": {
      "display": "Attenuation Multiplier",
      "type": "float",
      "default": 2.0,
      "minimum": 0.0
    },
    "bright_angle": {
      "display": "Bright Angle",
      "type": "float",
      "default": 45.0,
      "minimum": 0.0,
      "maximum": 90.0
    },
    "fading_angle": {
      "display": "Fading angle",
      "type": "float",
      "default": 60.0,
      "minimum": 0.0,
      "maximum": 90.0
    }
  }
}