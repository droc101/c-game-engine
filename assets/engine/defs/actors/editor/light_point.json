{
  "description": "Point light",
  "extends": "light",
  "renderers": [
    {
      "type": "point",
      "color": "$color"
    },
    {
      "type": "circle",
      "color": [
        "$color:r*0.5",
        "$color:g*0.5",
        "$color:b*0.5"
      ],
      "radius": "falloff($constant_attenuation, $linear_attenuation, $quadratic_attenuation, $attenuation_multiplier, 1)",
      "is_gizmo": true,
      "num_sides": 32
    },
    {
      "type": "circle",
      "color": "$color",
      "radius": "falloff($constant_attenuation, $linear_attenuation, $quadratic_attenuation, $attenuation_multiplier, 50)",
      "is_gizmo": true,
      "num_sides": 32
    }
  ],
  "params": {
    "constant_attenuation": {
      "display": "Constant Attenuation",
      "type": "float",
      "default": 0.0,
      "minimum": 0.0
    },
    "linear_attenuation": {
      "display": "Linear Attenuation",
      "type": "float",
      "default": 0.0,
      "minimum": 0.0
    },
    "quadratic_attenuation": {
      "display": "Quadratic Attenuation",
      "type": "float",
      "default": 1.0,
      "minimum": 0.0
    },
    "attenuation_multiplier": {
      "display": "Attenuation Multiplier",
      "type": "float",
      "default": 2.0,
      "minimum": 0.0
    }
  }
}